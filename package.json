{
  "name": "specimen",
  "version": "0.1.6",
  "private": true,
  "author": "Technical Standard",
  "description": "Specimen — Sovereign Runtime Environment for font asset retrieval and structural auditing",
  "homepage": "https://specimen.krtalabs.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/wisesakarta/specimen.git"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "typecheck:tasks": "tsc -p tsconfig.tasks.json --noEmit",
    "cleanup:workspace": "node tools/cleanup-workspace.mjs --apply",
    "cleanup:workspace:dry": "node tools/cleanup-workspace.mjs --dry-run",
    "qa:baseline": "npm run -s typecheck && npm run -s smoke:healthcheck",
    "smoke:healthcheck": "tsx tasks/smoke-foundry-healthcheck.ts",
    "smoke:intercept": "tsx tasks/smoke-browser-intercept.ts",
    "smoke:blazetype-catalog": "tsx tasks/blazetype-catalog-healthcheck.ts",
    "smoke:summary": "tsx tasks/smoke-report-summary.ts intercept",
    "smoke:all-foundries": "tsx tasks/smoke-all-foundries.ts",
    "smoke:abjad": "tsx tasks/abjad-precision-loop.ts --download",
    "crawl:catalog": "tsx tasks/catalog-crawler.ts --max-pages=12 --max-depth=1 --concurrency=2 --throttle-ms=250",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@react95/core": "^9.8.0",
    "@react95/icons": "^2.5.0",
    "@types/cheerio": "^0.22.35",
    "@types/opentype.js": "^1.3.9",
    "@types/pdf-parse": "^1.1.5",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "adm-zip": "^0.5.16",
    "brotli": "^1.3.3",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "fonteditor-core": "^2.6.3",
    "fontkit": "^2.0.4",
    "framer-motion": "^12.33.0",
    "gsap": "^3.14.2",
    "lenis": "^1.3.17",
    "lucide-react": "^0.563.0",
    "next": "^16.1.6",
    "opentype.js": "^1.3.4",
    "pdf-parse": "^2.4.5",
    "puppeteer": "^24.37.2",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^3.4.0",
    "wawoff2": "^2.0.1",
    "webamp": "^2.2.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-onboarding": "^10.3.6",
    "@storybook/nextjs": "^10.3.6",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-storybook": "^10.3.6",
    "postcss": "^8.5.6",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.1.18",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
